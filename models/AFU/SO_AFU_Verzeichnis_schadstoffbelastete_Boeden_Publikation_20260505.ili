    /** durch Strassen belastete Böden
     */
    CLASS Strasse
    EXTENDS SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505.Flaeche =
      /** Verkehrsfrequenz
       */
      Verkehrsfrequenz : (
        /** > 40'000 DTV
         */
        !!@ ili2db.dispName="> 40'000 DTV"
        DTV_groesser_als_40000,
        /** 20'000 - 40'000 DTV
         */
        !!@ ili2db.dispName="20'000 - 40'000 DTV"
        DTV_20000_40000,
