    /** militärischer Schiessplatz
     */
    CLASS militaerischer_Schiessplatz
    EXTENDS SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505.Flaeche =
      /** Name der Schiessanlage
       */
      Name_Schiessanlage : TEXT*50;
