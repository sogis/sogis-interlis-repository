INTERLIS 2.3;

/** !!-------------------------------------------------------------------------------------------------- 
 * !! Version    | wer | Änderung 
 * !!-------------------------------------------------------------------------------------------------- 
 * !! 2019-02-18| Noëmi Sturm    | Erstfassung 
 * !! 2019-03-04| Noëmi Sturm    | Mandatory Constraint angepasst 
 * !! 2020-05-04| Andrea Lüscher | Attribut "Nutzungsverbot" und "Nutzungseinschraenkung" ergänzt 
 * !! 2020-06-22| Andrea Lüscher | Anpassung Rückmeldung durch AFU aus der Testphase
 * !! 2020-07-01| Andrea Lüscher | Attribut "...inaktiv" heisst neu "aus_vsb_entlassen"
 * !! 2020-08-03| Andrea Lüscher | Verdachtsstreifenbreite 0_m und keine_Angabe entfernt
 * !! 2026-05-05| Patrick Bur    | Zusätzliches Aufzählelement 8_m Radius, neue Klasse PFAS, neue Attribute für View-Ersatz
 * !!==================================================================================================
 */
!!@ technicalContact=mailto:agi@bd.so.ch
!!@ furtherInformation=http://geo.so.ch/models/AFU/SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505.uml
MODEL SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505 (de)
AT "http://geo.so.ch/models/AFU"
VERSION "2026-05-05"  =
  IMPORTS GeometryCHLV95_V1;

  DOMAIN

    /** Betriebsstatus
     */
    Betriebsstatus = (
      !!@ ili2db.dispName="in Betrieb"
      in_Betrieb,
      stillgelegt,
      !!@ ili2db.dispName="rückgebaut"
      rueckgebaut
    );

  STRUCTURE Dokument =
    Name : TEXT*100;
    URL : INTERLIS.URI;
  END Dokument;

  STRUCTURE Schadstoff =
    Schadstoffname : TEXT*200;
    Kuerzel : TEXT*100;
  END Schadstoff;

  CLASS schadstoffbelasteter_Boden (ABSTRACT) =
    /** Bezeichnung der Geometrie
     */
    Bezeichnung : MANDATORY TEXT*200;
    /** Status
     */
    Status : MANDATORY (
      !!@ ili2db.dispName="Verdachtsfläche"
      Verdachtsflaeche,
      !!@ ili2db.dispName="Belastung nachgewiesen"
      Belastung_nachgewiesen
    );
    /** Ist die Flaeche aktiv?
     */
    aktiv : MANDATORY BOOLEAN;
    /** Erfassungsdatum
     */
    Erfassungsdatum : INTERLIS.XMLDate;
    /** Erfasser der Daten
     */
    Datenerfasser : TEXT*30;
    /** Begruendung fuer den Status inaktiv
     */
    Begruendung_aus_vsb_entlassen : (
      Dekontamination,
      !!@ ili2db.dispName="Verdachtsfläche wird Belastungsfläche"
      Verdachtsflaeche_wird_Belastungsflaeche,
      !!@ ili2db.dispName="entlastende Analysedaten"
      entlastende_Analysedaten,
      !!@ ili2db.dispName="grosse Mutation"
      grosse_Mutation,
      !!@ ili2db.dispName="anderer Grund"
      anderer_Grund
    );
    /** Datum an dem der Status inaktiv gesetzt wurde
     */
    Datum_aus_vsb_entlassen : INTERLIS.XMLDate;
    /** Bemerkung zum schadstoffbelasteten Boden
     */
    Bemerkung : MTEXT*2000;
    /** Wurden Nutzungseinschränkungen verfügt?
     */
    Nutzungseinschraenkung : MANDATORY BOOLEAN;
    /** Auflistung der dazugehoerigen Dokumente
     */
	 !!@ili2db.mapping=JSON
    Dokumente : BAG {0..*} OF SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505.Dokument;
    /** Auflistung der dazugehoerigen Schadstoffe
     */
	 !!@ili2db.mapping=JSON
    Schadstoffe : BAG {0..*} OF SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505.Schadstoff;
    /** BFS-Nr der betroffenen Gemeinden
     */
    BFS_Gemeindenummern : MANDATORY TEXT*255;
    /** Namen der betroffenen Gemeinden
     */
    Gemeindenamen : MANDATORY TEXT*255;
    /** Grundbuchnummern der betroffenen Liegenschaften
     */
    Grundbuchnummern : MANDATORY TEXT*100000;
    /** Namen der betroffenen Flure
     */
    Flurnamen : MANDATORY TEXT*10000;
    Nutzungsverbot : MANDATORY BOOLEAN;
    /** Öffentliche Bezeichnung des Trennkriteriums
     */
    Trennkriterium_oeffentlich : TEXT*255;
    /** Öffentliche Bezeichnung der Belastungsstufe
     */
    Belastungsstufe_oeffentlich : TEXT*255;
    /** Öffentliche Bezeichnung der Belastungsursache
     */
    Belastungsursache_oeffentlich : TEXT*255;
    /** Öffentliche Bezeichnung des Typs
     */
    Typ_oeffentlich : TEXT*255;
  END schadstoffbelasteter_Boden;

  CLASS Flaeche (ABSTRACT)
  EXTENDS schadstoffbelasteter_Boden =
    /** Fläche der Geometrie in m2
     */
    Flaeche : MANDATORY 0 .. 99999999;
    /** Umfang der Geometrie in m
     */
    Umfang : MANDATORY 0 .. 99999999;
    /** Geometrie der Flaeche
     */
    Geometrie : MANDATORY GeometryCHLV95_V1.MultiSurface;
  END Flaeche;

  TOPIC schadstoffbelastete_Boeden =
    OID AS INTERLIS.UUIDOID;

    /** Bodenbelastungsgebiet
     */
    CLASS Bodenbelastungsgebiet
    EXTENDS SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505.Flaeche =
      /** Verursacher
       */
      Verursacher : (
        /** Bearbeitung, Impraegnation und Verarbeitung von Holz
         */
        !!@ ili2db.dispName="Bearbeitung, Imprägnation und Verarbeitung von Holz"
        Holz,
        !!@ ili2db.dispName="chemische Reinigung"
        chemische_Reinigung,
        /** Eisen- und Stahlherstellung
         */
        !!@ ili2db.dispName="Eisen- und Stahlherstellung"
        Eisen_Stahlherstellung,
        Eisenbahn,
        /** Erzeugung und Verarbeitung von Leder
         */
        !!@ ili2db.dispName="Erzeugung und Verarbeitung von Leder"
        Erzeugung_Verarbeitung_Leder,
        Flugplatz,
        !!@ ili2db.dispName="Gaswerk, Kokerei, Steinkohle"
        Gaswerk_Kokerei_Steinkohle,
        !!@ ili2db.dispName="geogene Bodenbelastung"
        geogene_Bodenbelastung,
        /** Herstellung anorganischer Grundstoffen und Chemikalien
         */
        !!@ ili2db.dispName="Herstellung anorganischer Grundstoffen und Chemikalien"
        Herstellung_anorganische_Grundstoffe_Chemikalien,
        /** Herstellung und Verarbeitung von Glas
         */
        !!@ ili2db.dispName="Herstellung und Verarbeitung von Glas"
        Herstellung_Verarbeitung_Glas,
        /** Herstellung und Verarbeitung von Papier, Pappen und Textilen
         */
        !!@ ili2db.dispName="Herstellung und Verarbeitung von Papier, Pappen und Textilen"
        Herstellung_Verarbeitung_Papier_Pappe_Textile,
        /** Herstellung von Farben und Lacken
         */
        !!@ ili2db.dispName="Herstellung von Farben und Lacken"
        Herstellung_Farben_Lacke,
        /** Herstellung von Herbiziden, Fungiziden u.ae.
         */
        !!@ ili2db.dispName="Herstellung von Herbiziden, Fungiziden u.Ä."
        Herstellung_Herbi_Fungizide,
        /** Herstellung von Kunststoffen
         */
        !!@ ili2db.dispName="Herstellung von Kunststoffen"
        Herstellung_Kunststoffe,
        /** Herstellung von Phamazeutika
         */
        !!@ ili2db.dispName="Herstellung von Pharmazeutika"
        Herstellung_Pharmazeutika,
        Hopfenbau,
        Kehrichtverbrennungsanlage,
        !!@ ili2db.dispName="Klärschlamm"
        Klaerschlamm,
        Metallgiesserei,
        Metallverarbeitung,
        /** Mineraloelverarbeitung / -lagerung
         */
        !!@ ili2db.dispName="Mineralölverarbeitung / -lagerung"
        Mineraloel,
        /** Muellkompost, kommunale Kehrichtdeponie, Altablagerung
         */
        !!@ ili2db.dispName="Müllkompost, kommunale Kehrichtdeponie, Altablagerung"
        Muell,
        /** Oberflächenveredelung / Härtung von Metallen
         */
        !!@ ili2db.dispName="Oberflächenveredelung / Härtung von Metallen"
        Oberflaechenveredelung_Haertung_Metalle,
        Rebbau,
        Schiessanlage,
        Schrebergarten,
        Siedlungsgebiet,
        /** Sondermüllentsorgungs- und -verbrennungsanlage
         */
        !!@ ili2db.dispName="Sondermüllentsorgungs- und Verbrennungsanlage"
        Sondermuell,
        Korrosionsschutz,
        Strasse,
        !!@ ili2db.dispName="Übertragungsleitungsmast"
        Uebertragungsleitungsmast,
        /** Verarbeitung von Gummi, Kunststoffen und Asbest
         */
        !!@ ili2db.dispName="Verarbeitung von Gummi, Kunststoffen und Asbest"
        Verarbeitung_Gummi_Kunststoffe_Asbest,
        Buntmetallwerk,
        Schadenfall,
        unbekannt,
        Gartennutzung
      );
      /** Belastungsstufe
       */
      Belastungsstufe : (
        /** Pruefwert bis Sanierungswert (PW-SW)
         */
        !!@ ili2db.dispName="Prüfwert bis Sanierungswert (PW-SW)"
        Pruefwert_bis_Sanierungswert,
        /** Richtwert bis Pruefwert (RW-PW)
         */
        !!@ ili2db.dispName="Richtwert bis Prüfwert (RW-PW)"
        Richtwert_bis_Pruefwert,
        /** Pruefwert B bis Sanierungswert (PWB-SW)
         */
        !!@ ili2db.dispName="Prüfwert B bis Sanierungswert (PWB-SW)"
        Pruefwert_B_bis_Sanierungswert,
        /** Pruefwert A bis Pruefwert B (PWA-PWB)
         */
        !!@ ili2db.dispName="Prüfwert A bis Prüfwert B (PWA-PWB)"
        Pruefwert_A_bis_Pruefwert_B,
        /** Pruefwert bis Pruefwert A (PW-PWA)
         */
        !!@ ili2db.dispName="Prüfwert bis Prüfwert A (PW-PWA)"
        Pruefwert_bis_Pruefwert_A,
        /** > Sanierungswert (>SW)
         */
        !!@ ili2db.dispName="> Sanierungswert (>SW)"
        groesser_als_Sanierungswert
      );
      /** Zusatztext für den Prüfwert
       */
      Pruefwert : TEXT*50;
      /** Anzahl der Proben
       */
      Probenanzahl : 0 .. 9999;
      /** Ist ein Eintrag im Grundbuch vorhanden?
       */
      Grundbucheintrag : BOOLEAN;
      /** Typ der Bodenbelastungsfläche
       */
      Flaechentyp : MANDATORY (
        Bodenbelastungsgebiet,
        !!@ ili2db.dispName="übrige"
        uebrige
      );
      Gebietsname : MANDATORY TEXT*128;
      MANDATORY CONSTRAINT (Flaechentyp == #uebrige AND DEFINED(Grundbucheintrag)) OR (Flaechentyp != #uebrige );
    END Bodenbelastungsgebiet;

    /** Eisenbahn
     */
    CLASS Eisenbahn
    EXTENDS SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505.Flaeche =
      /** Typ der Fläche
       */
      Flaechentyp : (
        /** Bahnhofareal (Gueter und Personen)
         */
        !!@ ili2db.dispName="Bahnhofareal (Güter und Personen)"
        Bahnhofareal,
        !!@ ili2db.dispName="Verdachtsstreifen entlang Gleise"
        Verdachtsstreifen_entlang_Gleise,
        Tunnelstrecke
      );
      /** Verkehrsfrequenz der Bahn
       */
      Verkehrsfrequenz : (
        /** > 50'000 GBRT
         */
        !!@ ili2db.dispName="> 50'000 GBRT"
        groesser_als_50000_GBRT,
        /** 20'000 - 50'000 GBRT
         */
        !!@ ili2db.dispName="20'000 - 50'000 GBRT"
        GBRT_20000_50000,
        /** < 20'000 GBRT
         */
        !!@ ili2db.dispName="< 20'000 GBRT"
        kleiner_als_20000_GBRT
      );
      /** Breite des Verdachtsstreifens
       */
      Verdachtsstreifenbreite : (
        /** 15 m
         */
        !!@ ili2db.dispName="15 m"
        m_15,
        /** 10 m
         */
        !!@ ili2db.dispName="10 m"
        m_10,
        /** 5 m
         */
        !!@ ili2db.dispName="5 m"
        m_5,
        !!@ ili2db.dispName="kein Verdachtsstreifen"
        kein_Verdachtsstreifen
      );
      /** Öffentliche Bezeichnung des Verdachtsstreifens
       */
      Verdachtsstreifenbreite_oeffentlich : TEXT*255;
      /** Anzahl der Gleise
       */
      Gleisanzahl : 0 .. 10;
      /** Bahnstrecke von
       */
      Strecke_von : TEXT*50;
      /** Bahnstrecke bis
       */
      Strecke_bis : TEXT*50;
      /** Name des Transportunternehmens
       */
      Transportunternehmen : TEXT*120;
    END Eisenbahn;

    /** Flugplatz
     */
    CLASS Flugplatz
    EXTENDS SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505.Flaeche =
      /** Name des Flugplatzes
