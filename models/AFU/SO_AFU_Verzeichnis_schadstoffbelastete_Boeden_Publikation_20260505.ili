         */
        !!@ ili2db.dispName="3'000 - 20'000 DTV"
        DTV_3000_20000,
        /** 1'000 - 3'000 DTV
         */
        !!@ ili2db.dispName="1'000 - 3'000 DTV"
        DTV_1000_3000
      );
      /** Breite des Verdachtsstreifens ab Fahrbahnrand
       */
      Verdachtsstreifenbreite : (
        /** 15 m
         */
        !!@ ili2db.dispName="15 m"
        m_15,
        /** 10 m
         */
        !!@ ili2db.dispName="10 m"
        m_10,
        /** 5 m
         */
        !!@ ili2db.dispName="5 m"
        m_5,
        !!@ ili2db.dispName="kein Verdachtsstreifen"
        kein_Verdachtsstreifen
      );
      /** Öffentliche Bezeichnung des Verdachtsstreifens
       */
      Verdachtsstreifenbreite_oeffentlich : TEXT*255;
      /** Strassentyp
       */
      Strassentyp : (
        Kantonsstrasse,
        Nationalstrasse
      );
    END Strasse;

    /** Flaechen mit nachgewiesener PFAS-Belastung
     */
    CLASS PFAS
    EXTENDS SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505.Flaeche =
      /** Vermutete PFAS-Quelle
       */
      Vermutete_Quelle : TEXT*200;
    END PFAS;

  END schadstoffbelastete_Boeden;

END SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505.