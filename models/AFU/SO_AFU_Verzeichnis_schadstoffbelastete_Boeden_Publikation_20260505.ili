    /** Schiessanlage
     */
    CLASS Schiessanlage
    EXTENDS SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505.Flaeche =
      /** Trennkriterium
       */
      Trennkriterium : (
        /** andere Schiessanlage: Einzelfallabkaerung (Combat, Feld, Jagd, KK, Pst, Tontauben)
         */
        !!@ ili2db.dispName="andere Schiessanlage"
        andere_Schiessanlage,
        /** kleine 300-m-Schiessanlage: < 15'000 Schuss/Jahr
         */
        !!@ ili2db.dispName="kleine 300-m-Schiessanlage"
        kleine_300_m_Schiessanlage,
        /** mittlere 300-m-Schiessanlage: zwischen 15'000 und 40'000 Schuss/Jahr
         */
        !!@ ili2db.dispName="mittlere 300-m-Schiessanlage"
        mittlere_300_m_Schiessanlage,
        /** grosse 300-m-Schiessanlage: > 40'000 Schuss/Jahr
         */
        !!@ ili2db.dispName="grosse 300-m-Schiessanlage"
        grosse_300_m_Schiessanlage
      );
      /** Name des Schiessplatzes
       */
      Name_Schiessanlage : TEXT*50;
      /** Baujahr
       */
      Baujahr : INTERLIS.GregorianYear;
      /** Anzahl Zielscheiben
       */
      Scheibenanzahl : 0 .. 1000;
      /** Schusszahl pro Jahr
       */
      Schusszahl_Jahr : 0 .. 9999999;
      /** Lage
       */
      Lage : TEXT*200;
      /** Betriebsstatus
       */
      Betriebsstatus : SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505.Betriebsstatus;
      /** Laufnummer Altlasten
       */
      KbS_Nummer : TEXT*50;
      /** Sanierungsstatus der Schiessanlage
       */
      Sanierungsstatus : (
        !!@ ili2db.dispName="Kugelfang saniert"
        Kugelfang_saniert,
        !!@ ili2db.dispName="Kugelfang nicht saniert"
        Kugelfang_nicht_saniert
      );
      /** Arten der Schiessanlagen
       */
      Schiessanlagentypen : MANDATORY TEXT*300;
      Waffe : TEXT*200;
      URL_KbS : INTERLIS.URI;
    END Schiessanlage;

