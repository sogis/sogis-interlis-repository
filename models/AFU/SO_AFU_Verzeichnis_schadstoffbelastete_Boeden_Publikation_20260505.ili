      Flugplatzname : TEXT*50;
      /** Öffentliche Bezeichnung der Ausdehnung
       */
      Ausdehnung_oeffentlich : TEXT*255;
    END Flugplatz;

    /** durch Gärtnerei belastete Böden
     */
    CLASS Gaertnerei
    EXTENDS SO_AFU_Verzeichnis_schadstoffbelastete_Boeden_Publikation_20260505.Flaeche =
      /** Name des Schrebergartens oder der Gaertnerei
