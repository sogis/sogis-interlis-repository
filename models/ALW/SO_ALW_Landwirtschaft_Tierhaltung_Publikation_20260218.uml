<ch.ehi.basics.types.NlsString TID="5916">
<Entry TID="5918" language="de" translation="Kodierung Kulturtyp (artcd im System GELAN):&#10;42050 = unbestimmt&#10;42055 = Wiese&#10;42060 = Weide&#10;42061 = Weide (BE)&#10;42065 = Hecken&#10;42070 = B&#228;ume&#10;42075 = Reben&#10;&#10;Strukturierte Darstellung aller Code-Kombinationen (GELAN):&#10;&#10;typcd 42000 = BFF2 DZV&#10;-artcd 42050 = unbestimmt&#10;--strukturcd 42035 = Q normal&#10;-artcd 42055 = Wiese&#10;--strukturcd 42035 = Q normal&#10;-artcd 42060 = Weide&#10;--strukturcd 42040 = Q Struktur&#10;--strukturcd 42045 = Q Flora&#10;--strukturcd 42046 = Q Struktur &amp; Flora&#10;-artcd 42061 = Weide (BE)&#10;--strukturcd 42049 = Q aus Natur Inv.&#10;-artcd 42065 = Hecken&#10;--strukturcd 42035 = Q normal&#10;-artcd 42070 = B&#228;ume&#10;--strukturcd 42035 = Q normal&#10;-artcd 42075 = Reben&#10;--strukturcd 42035 = Q normal&#10;&#10;typcd 42005 = Natur NS-Vertr&#228;ge&#10;-artcd 42050 = unbestimmt&#10;--strukturcd 42048 = BFF exklusive&#10;-artcd 42055 = Wiese&#10;--strukturcd 42048 = BFF exklusive&#10;-artcd 42060 = Weide&#10;--strukturcd 42048 = BFF exklusive&#10;-artcd 42065 = Hecken&#10;--strukturcd 42048 = BFF exklusive&#10;&#10;typcd 42010 = BFF2 S&#246;mmerung&#10;-artcd 42050 = unbestimmt&#10;--strukturcd 42030 = keine Angabe&#10;--strukturcd 42049 = Q aus Natur Inv."/>
</ch.ehi.basics.types.NlsString>
