</ch.ehi.uml1_4.implementation.UmlMultiplicityRange>
<ch.ehi.basics.types.NlsString TID="6855">
<Entry TID="6870" language="de" translation="Massgebende Anzahl B&#228;ume f&#252;r BFF2-Qualit&#228;t innerhalb des BFF2-Polygons.&#10;Hinweis: z.B. Wiesen- und Weidepolygone haben Baumzahl =0."/>
</ch.ehi.basics.types.NlsString>
<ch.ehi.basics.types.NlsString TID="6857">
<Entry TID="6871" language="de" translation="Qualitaetsvariante_Code"/>
</ch.ehi.basics.types.NlsString>
<ch.ehi.basics.types.NlsString TID="6860">
<Entry TID="6872" language="de" translation="Kodierung Qualit&#228;ts-Variante (strukturcd im System GELAN):&#10;42030 = keine Angabe&#10;42031 = kein BFF-Ausschluss (bei TWW ohne Vertrag)&#10;42035 = Q normal&#10;42040 = Q Struktur&#10;42045 = Q Flora&#10;42046 = Q Struktur &amp; Flora&#10;42048 = BFF exklusive (Standard f&#252;r Naturpolygone; BFF wird durch &#252;berlagerung mit BFF2-Polygon erwirkt)&#10;42049 = Q aus Natur Inv.&#10;&#10;Strukturierte Darstellung aller Code-Kombinationen(GELAN):&#10;&#10;typcd 42000 = BFF2 DZV&#10;-artcd 42050 = unbestimmt&#10;--strukturcd 42035 = Q normal&#10;-artcd 42055 = Wiese&#10;--strukturcd 42035 = Q normal&#10;-artcd 42060 = Weide&#10;--strukturcd 42040 = Q Struktur&#10;--strukturcd 42045 = Q Flora&#10;--strukturcd 42046 = Q Struktur &amp; Flora&#10;-artcd 42061 = Weide (BE)&#10;--strukturcd 42049 = Q aus Natur Inv.&#10;-artcd 42065 = Hecken&#10;--strukturcd 42035 = Q normal&#10;-artcd 42070 = B&#228;ume&#10;--strukturcd 42035 = Q normal&#10;-artcd 42075 = Reben&#10;--strukturcd 42035 = Q normal&#10;&#10;typcd 42005 = Natur NS-Vertr&#228;ge&#10;-artcd 42050 = unbestimmt&#10;--strukturcd 42048 = BFF exklusive&#10;-artcd 42055 = Wiese&#10;--strukturcd 42048 = BFF exklusive&#10;-artcd 42060 = Weide&#10;--strukturcd 42048 = BFF exklusive&#10;-artcd 42065 = Hecken&#10;--strukturcd 42048 = BFF exklusive&#10;&#10;typcd 42010 = BFF2 S&#246;mmerung&#10;-artcd 42050 = unbestimmt&#10;--strukturcd 42030 = keine Angabe&#10;--strukturcd 42049 = Q aus Natur Inv."/>
</ch.ehi.basics.types.NlsString>
