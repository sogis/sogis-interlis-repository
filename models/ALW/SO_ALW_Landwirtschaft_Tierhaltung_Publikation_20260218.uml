<ch.ehi.basics.types.NlsString TID="3126">
<Entry TID="4184" language="de" translation="Standorttyp im Agrarinformationssystem GELAN:&#10;Allgemein;&#10;Bienenstand;&#10;Fischzucht;&#10;Schlachthof;&#10;Tierstandort ohne TVD;&#10;Tierstandort TVD;&#10;Tierstandort TVD leerstehend;&#10;&#10;Zur Information wird nachfolgend die Klassifizierung der Betriebstypen gem&#228;ss AGIS Bund aufgef&#252;hrt:&#10;Anerkannt nach LBV;&#10;Betriebsgemeinschaft;&#10;Biogasanlage;&#10;Gemeinschaftsweidebetriebe;&#10;GS Betrieb;&#10;Kompostieranlage;&#10;LBV ohne DZ;&#10;nicht kommerzielle Tierhaltung;&#10;nicht LBV (&#252;brige);&#10;S&#246;mmerungsbetrieb;&#10;Schlachthof;&#10;Tierschauen;&#10;Viehhandelsunternehmen;&#10;Wanderherde;&#10;&#10;AGIS Bund gibt f&#252;r Betriebsform folgende m&#246;gliche Werte vor:&#10;M&#246;gliche Werte:&#10;- 01 = Betrieb (=Ganzjahresbetrieb)&#10;- 02 = Produktionsst&#228;tte&#10;- 04 = Gemeinschaftsweidebetrieb&#10;- 05 = S&#246;mmerungsbetrieb&#10;- 06 = Betriebsgemeinschaft&#10;- 09 = Viehhandelsunternehmen&#10;- 10 = Wanderherde&#10;- 11 = Tierklinik&#10;- 12 = Schlachtbetriebe&#10;- 13 = Viehm&#228;rkte, Viehauktionen, Viehausstellungen und &#228;hnliche Veranstaltungen&#10;- 14 = Betriebszweiggemeinschaft&#10;- 15 = Nichtkommerzielle Tierhaltung&#10;- 16 = &#214;LN-Gemeinschaft (*)&#10;- 17 = Verg&#228;rungs- und Kompostierungsanlage (*)&#10;- 20 = Tierhaltung&#10;- 99 = Nicht zugeteilt (*)&#10;* Auf dieser Betriebsform kann keine TVD-Nummer vergeben werden"/>
</ch.ehi.basics.types.NlsString>
<ch.ehi.basics.types.NlsString TID="2661">
