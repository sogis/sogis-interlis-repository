<ch.ehi.basics.types.NlsString TID="2208">
<Entry TID="2354" language="de" translation="Beinhaltet die administrative Zonenzugeh&#246;rigkeit der zugeordneten Bewirtschaftungseinheit (Zone, in welcher die Beirtschaftungseinheit den gr&#246;ssten Fl&#228;chenanteil hat).&#10;Die Zone der Bewirtschaftungseinheit ist f&#252;r die Kultur massgebend.&#10;M&#246;gliche Werte:&#10;- 31=Talzone&#10;- 41=H&#252;gelzone&#10;- 51=Bergzone 1&#10;- 52=Bergzone 2&#10;- 53=Bergzone 3&#10;- 54=Bergzone 4&#10;- 61=S&#246;mmerungsgebiet,&#10;- 77=angestammten Fl&#228;chen im Ausland&#10;- 79=nicht angestammten Fl&#228;chen im Ausland&#10;- 99=Nicht zugeteilt"/>
</ch.ehi.basics.types.NlsString>
