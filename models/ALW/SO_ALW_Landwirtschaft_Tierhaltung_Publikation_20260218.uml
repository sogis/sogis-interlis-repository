<ch.ehi.basics.types.NlsString TID="6843">
<Entry TID="6850" language="de" translation="BFF_Qualitaet"/>
</ch.ehi.basics.types.NlsString>
<ch.ehi.basics.types.NlsString TID="6844">
<Entry TID="6851" language="de" translation="Abgrenzung der Qualit&#228;t BFF2 f&#252;r Biodiversit&#228;tsf&#246;rderfl&#228;chen im Agrarinformationssystems GELAN. Naturschutzvertr&#228;ge welche ins Agrarinforamtionssystem GELAN importiert wurden, werden in diesem Thema mit entsprechender Typisierung abgebildet.&#10;Die Qualit&#228;tspolygone werden unabh&#228;ngig von den Bewirtschaftungseinheiten und den Kulturpolygonen erfasst."/>
</ch.ehi.basics.types.NlsString>
