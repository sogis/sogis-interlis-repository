<ch.ehi.basics.types.NlsString TID="3092">
<Entry TID="3100" language="de" translation="Eine Anpassung des Richtplans erfolgt nach den Vorgaben der Raumplanungsgesetzgebung (Raumplanungsgesetz sowie -verordnung)j&#228;hrlich. Mit der Genehmigung durch den Regierungsrat wird der Richtplan f&#252;r jegliche Beh&#246;rden im Kanton verbindlich. Mit der Genehmigung durch das UVEK wird der Richtplan auch f&#252;r die Beh&#246;rden der Nachbarkantone sowie f&#252;r die Bundesbeh&#246;rden verbindlich. "/>
</ch.ehi.basics.types.NlsString>
